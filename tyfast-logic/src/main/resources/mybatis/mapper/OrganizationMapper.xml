<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ty.logic.system.dao.OrganizationDao">

    <!-- 关系映射 -->
    <resultMap id="OrganizationMap" type="Organization">
        <result property="orgId" column="org_id" />
        <result property="parentId" column="parent_id" />
        <result property="orgCode" column="org_code" />
        <result property="orgName" column="org_name" />
        <result property="provinceId" column="province_id" />
        <result property="provinceName" column="province_name" />
        <result property="cityId" column="city_id" />
        <result property="cityName" column="city_name" />
        <result property="lng" column="lng" />
        <result property="lat" column="lat" />
        <result property="remark" column="remark" />
        <result property="createUser" column="create_user" />
        <result property="createTime" column="create_time" />
        <result property="updateUser" column="update_user" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <!-- 查询条件 -->
    <sql id="condition_organization">
        <where>
            <if test="orgId != null and orgId != ''">
                and t.org_id=#{orgId}
            </if>
            <if test="parentId != null and parentId != ''">
                and t.parent_id=#{parentId}
            </if>
            <if test="orgCode != null and orgCode != ''">
                and t.org_code=#{orgCode}
            </if>
            <if test="orgName != null and orgName != ''">
                and t.org_name
                <choose>
                    <when test="isLike != null and isLike == false">
                        =#{orgName}
                    </when>
                    <otherwise>
                        LIKE CONCAT('%',#{orgName},'%')
                    </otherwise>
                </choose>
            </if>
            <if test="ids != null and ids.size() != 0">
                and t.org_id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
        </where>
    </sql>

    <!-- 查询记录数 -->
    <select id="findOrganizationCount" parameterType="Organization" resultType="java.lang.Integer">
        SELECT count(0) FROM t_organization t
        <include refid="condition_organization" />
    </select>

    <!-- 查询结果集 -->
    <select id="findOrganization" parameterType="Organization" resultMap="OrganizationMap">
        SELECT
            t.org_id,
            t.parent_id,
            t.org_code,
            t.org_name,
            t.province_id,
            t.province_name,
            t.city_id,
            t.city_name,
            t.lng,
            t.lat,
            t.remark,
            t.create_user,
            t.create_time,
            t.update_user,
            t.update_time
        FROM
            t_organization t
        <include refid="condition_organization" />
        ORDER BY t.org_id DESC
    </select>

    <!-- 根据ID查询记录 -->
    <select id="findOrganizationById" parameterType="java.lang.String" resultMap="OrganizationMap">
        SELECT
            t.org_id,
            t.parent_id,
            t.org_code,
            t.org_name,
            t.province_id,
            t.province_name,
            t.city_id,
            t.city_name,
            t.lng,
            t.lat,
            t.remark,
            t.create_user,
            t.create_time,
            t.update_user,
            t.update_time
        FROM
            t_organization t
        WHERE t.org_id = #{orgId}
    </select>

    <!-- 查询指定机构的所有子机构 -->
    <select id="findOrgChildren" parameterType="java.lang.String" resultMap="OrganizationMap">
        SELECT
            t.org_id,
            t.org_name
        FROM
            t_organization t
        WHERE FIND_IN_SET(org_id,queryChildrenNodes('t_organization', #{orgId}))
    </select>

    <!-- 查询机构的根机构 -->
    <select id="findRootOrganization" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT queryRootNodeForChild(#{orgId})
    </select>

    <!-- 保存 -->
    <insert id="saveOrganization" parameterType="Organization">
        INSERT INTO t_organization
        (
        <trim suffix="" suffixOverrides=",">
            <if test="orgId != null">org_id,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="orgCode != null">org_code,</if>
            <if test="orgName != null">org_name,</if>
            <if test="provinceId != null">province_id,</if>
            <if test="provinceName != null">province_name,</if>
            <if test="cityId != null">city_id,</if>
            <if test="cityName != null">city_name,</if>
            <if test="lng != null">lng,</if>
            <if test="lat != null">lat,</if>
            <if test="remark != null">remark,</if>
            <if test="createUser != null">create_user,</if>
            create_time,
            <if test="updateUser != null">update_user,</if>
            update_time,
        </trim>
        )
        VALUES
        (
        <trim suffix="" suffixOverrides=",">
            <if test="orgId != null">#{orgId},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="orgCode != null">#{orgCode},</if>
            <if test="orgName != null">#{orgName},</if>
            <if test="provinceId != null">#{provinceId},</if>
            <if test="provinceName != null">#{provinceName},</if>
            <if test="cityId != null">#{cityId},</if>
            <if test="cityName != null">#{cityName},</if>
            <if test="lng != null">#{lng},</if>
            <if test="lat != null">#{lat},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createUser != null">#{createUser},</if>
            now(),
            <if test="updateUser != null">#{updateUser},</if>
            now(),
        </trim>
        )
    </insert>

    <!-- 修改 -->
    <update id="updateOrganization" parameterType="Organization">
        UPDATE t_organization
        <set>
            <if test="orgId != null">org_id=#{orgId},</if>
            <if test="parentId != null">parent_id=#{parentId},</if>
            <if test="orgCode != null">org_code=#{orgCode},</if>
            <if test="orgName != null">org_name=#{orgName},</if>
            <if test="provinceId != null">province_id=#{provinceId},</if>
            <if test="provinceName != null">province_name=#{provinceName},</if>
            <if test="cityId != null">city_id=#{cityId},</if>
            <if test="cityName != null">city_name=#{cityName},</if>
            <if test="lng != null">lng=#{lng},</if>
            <if test="lat != null">lat=#{lat},</if>
            <if test="remark != null">remark=#{remark},</if>
            <if test="updateUser != null">update_user=#{updateUser},</if>
            update_time=now()
        </set>
        WHERE org_id = #{orgId}
    </update>

    <!-- 删除 -->
    <delete id="delOrganization" parameterType="Organization">
        DELETE FROM t_organization WHERE org_id = #{orgId}
    </delete>
</mapper>
